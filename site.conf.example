# unveil — site configuration
# Copy to site.conf and edit. All settings have sensible defaults.
#
# Required: DOMAIN
# Everything else is optional with documented defaults.

# Domain name (required — used in indexes, manifests, GPG key)
DOMAIN=example.com

# Source directory (your original files + scripts)
UTILS_DIR=/var/www/utils/$DOMAIN

# Web root (where encrypted output goes)
HTDOCS_DIR=/var/www/htdocs/$DOMAIN

# Passphrase word count (default: 12, ~120 bits entropy)
PASSPHRASE_WORDS=12

# PBKDF2 iterations (higher = slower unlock, more secure)
PBKDF2_ITERATIONS=260000

# GPG key email for signing (auto-generated if not found)
GPG_EMAIL=admin@$DOMAIN

# Web server — bootstrap.sh generates config for the selected server
#   openbsd-httpd  OpenBSD native httpd
#   nginx          nginx with Let's Encrypt via certbot
#   apache         Apache 2.4 with mod_ssl + certbot
#   caddy          Caddy (automatic HTTPS, zero config TLS)
#   none           no server config (static hosting, S3, etc.)
HTTPD=none

# TLS certificate provider
#   acme    Let's Encrypt (acme-client on OpenBSD, certbot elsewhere)
#   caddy   Caddy handles TLS automatically
#   none    no TLS setup (you handle it, or plain HTTP)
TLS=none

# Passphrase persistence in browser
#   none     prompt every page
#   session  persist until tab/browser closes (sessionStorage)
#   local    persist until manually cleared (localStorage)
PASSPHRASE_PERSIST=session

# Reveal mode — embed passphrase so pages auto-decrypt without prompting.
# Encryption + signatures remain intact (proves authorship), content is public.
#   none  all pages locked (default)
#   all   entire site revealed
# Per-directory: put files in html-public/ instead of html/
# Per-file: list filenames in utils/reveal.txt (one per line)
REVEAL=none

# Hash tree — distribute encrypted files in a ternary directory tree
# for efficient filesystem lookup on FFS/UFS (O(n) -> O(1) per level).
#   flat     all files in one directory (default, fine for <1000 files)
#   ternary  3-way hash tree (dirs named 0, 1, 2)
HASH_TREE=flat

# Tree depth (1-4). Capacity = 3^depth * 243 files.
#   1 = 729, 2 = 2187, 3 = 6561, 4 = 19683
HASH_TREE_DEPTH=4

# Selective reveal by tree path — file in UTILS_DIR listing tree paths
# to reveal or lock. See tree.conf.example. Only applies when HASH_TREE=ternary.
# TREE_CONF=tree.conf

# Landing page footer links (leave blank to hide)
CONTACT_EMAIL=
GIT_REPO=

# Show manifest links on landing page
#   yes  show link (default for manifest.txt)
#   no   hide link
SHOW_MANIFEST_TXT=yes
SHOW_MANIFEST_HTML=yes

# Rollback strategy
#   disk     hardlink snapshots in .snapshots/ (default, max 2)
#   tree     use unused ternary nodes for versioning (requires HASH_TREE=ternary)
#   git      commit htdocs to a git repo after each publish
#   none     no rollback
ROLLBACK=disk
MAX_ROLLBACKS=2

# Compression — zlib-compress plaintext before encryption for files above
# this size (bytes). Client browser decompresses after decryption using
# DecompressionStream API. Set to 0 to disable.
#   102400 = 100KB (recommended — most HTML files benefit)
#   0      = no compression
COMPRESS_THRESHOLD=102400

# Landing page prominent links — show Appendix and Corpus navigation
#   yes  show link in landing page header, files page, and manifest
#   no   hide (default)
SHOW_APPENDIX=no
SHOW_CORPUS=no

# Paths for appendix/corpus links (relative to web root)
# APPENDIX_PATH=corpus/appendix.html
# CORPUS_PATH=corpus/rawcorpus.html
